---
import '../styles/global.css';

const site = Astro.site;
if (!site) {
	throw new Error('astro.config.mjs must set `site` for canonical and Open Graph image URLs.');
}
const baseUrl = new URL(import.meta.env.BASE_URL, site);
const canonicalURL = baseUrl.href;
const ogImageURL = new URL('og-card.png', baseUrl).href;

const seoTitle = 'VarMonitor | Runtime observability and deterministic replay for C++ systems';
const seoDescription =
	'VarMonitor gives C++ and embedded teams live internal visibility, deterministic recording/replay, anomaly analysis, and remote debug workflows with low runtime overhead.';

const base = import.meta.env.BASE_URL;
const docsHrefEn = 'docs/en/index.html';
const architectureVideoSrc = `${base}videos/live_sencillo.mp4`;
/** Deep links into MkDocs (EN, use_directory_urls: false → .html) */
const docsMk = {
	cpp: `${base}docs/en/cpp-integration.html`,
	shm: `${base}docs/en/architecture.html#3-shared-memory-segment-association`,
	consumer: `${base}docs/en/backend.html#websocket-flow-in-websocket_endpoint`,
};

const extensibilityCards = [
	{
		title: 'Observability & Interactive Control',
		body: 'Live variables, real-time dashboards, event-aware views, and optional joystick-assisted control for dynamic runtime testing.',
		videoThumbSrc: `${base}videos/live_3d.mp4`,
		videoModalSrc: `${base}videos/live_3d.mp4`,
		svgPath:
			'M14 10l-2 1m0 0l-2-1m2 1v2.5M20 7l-2 1m2-1l-2-1m2 1v2.5M14 5l-2-1-2 1M4 5l2-1M4 5l2 1M4 5v2.5M12 21l-2-1m2 1l2-1m-2 1v-2.5M6 18l-2-1v-2.5M18 18l2-1v-2.5',
	},
	{
		title: 'Analysis & Reporting',
		body: 'Offline analysis workflows, anomaly detection support, and report-ready outputs to document behavior and compare runs.',
		svgPath:
			'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
	},
	{
		title: 'Remote IDE & Debug',
		body: 'Web-based remote debugging, file browsing/editing, fast regex indexing, and lightweight debugger integration for rapid iteration.',
		videoThumbSrc: `${base}videos/archivo_bien.mp4`,
		videoModalSrc: `${base}videos/archivo_bien.mp4`,
		svgPath: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
	},
	{
		title: 'Git Interface',
		body: 'Remote repository management from the web interface, enabling operational Git workflows without leaving the monitoring environment.',
		videoThumbSrc: `${base}videos/git.mp4`,
		videoModalSrc: `${base}videos/git.mp4`,
		svgPath: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6',
	},
	{
		title: 'Apache Parquet Recording',
		body: 'Optimized recording for large datasets with Apache Parquet output, compatible with ring-buffer capture paths controlled through configurable launch flags.',
		svgPath:
			'M4 7h16M6 4h12a2 2 0 012 2v12a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2zm2 5h8m-8 4h8m-8 4h5',
	},
	{
		title: 'ARINC 429 & MIL-STD-1553',
		body: 'Real-time protocol decoding with parity/SSM validation and extendable user-defined databases for avionics-oriented workflows.',
		videoThumbSrc: `${base}videos/ficha_arinc.mp4`,
		videoModalSrc: `${base}videos/live_arinc.mp4`,
		svgPath:
			'M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071c3.904-3.905 10.236-3.905 14.141 0M1.394 9.393c5.857-5.857 15.355-5.857 21.213 0',
		featured: true,
	},
];
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={seoDescription} />
		<meta name="theme-color" content="#020617" />
		<link rel="canonical" href={canonicalURL} />
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="VarMonitor" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={seoTitle} />
		<meta property="og:description" content={seoDescription} />
		<meta property="og:image" content={ogImageURL} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content="VarMonitor wordmark on a dark slate background with cyan-blue gradient" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={seoTitle} />
		<meta name="twitter:description" content={seoDescription} />
		<meta name="twitter:image" content={ogImageURL} />
		<title>{seoTitle}</title>
	</head>
	<body class="min-h-dvh bg-slate-950 text-slate-300 antialiased selection:bg-cyan-500/20 selection:text-cyan-100">
		<div id="bg-spotlight" aria-hidden="true" class="pointer-events-none fixed inset-0 -z-10 opacity-80"></div>
		<div id="bg-grain" aria-hidden="true" class="pointer-events-none fixed inset-0 z-[99] opacity-[0.025]"></div>

		<header class="sticky top-0 z-50 border-b border-white/5 bg-slate-950/80 backdrop-blur-md">
			<div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6 lg:px-8">
				<a
					href="#top"
					class="inline-flex items-center gap-1.5 font-mono text-sm transition hover:opacity-90"
					aria-label="VarMonitor home"
				>
					<span class="bg-gradient-to-r from-cyan-400 to-blue-500 bg-clip-text text-transparent">
						<span class="font-bold">VAR</span><span class="font-light">MONITOR</span>
					</span>
					<span class="logo-status-led size-[5px] shrink-0 rounded-full bg-cyan-400" aria-hidden="true"></span>
				</a>
				<div class="flex items-center gap-3">
					<a
						href={docsHrefEn}
						class="rounded-lg border border-white/10 bg-white/5 px-3 py-2 text-sm font-medium text-slate-200 transition hover:border-cyan-500/35 hover:bg-cyan-500/10 hover:text-cyan-200"
					>
						Technical Information
					</a>
					<a
						href="https://github.com/LorenzoAdr/RealTimeMonitor"
						target="_blank"
						rel="noopener noreferrer"
						class="rounded-lg border border-white/10 bg-white/5 px-3 py-2 text-sm font-medium text-slate-200 transition hover:border-cyan-500/35 hover:bg-cyan-500/10 hover:text-cyan-200"
					>
						GitHub
					</a>
				</div>
			</div>
		</header>

		<div id="top" class="sr-only" aria-hidden="true"></div>

		<main>
			<div class="pointer-events-none fixed right-4 top-24 z-40">
				<div class="rounded-full border border-white/10 bg-slate-950/88 px-3 py-1.5 shadow-lg shadow-black/30 backdrop-blur-md">
					<p id="vm-stepper-current" class="font-mono text-[11px] uppercase tracking-[0.16em] text-cyan-200/95">1/5 Overview</p>
				</div>
			</div>

			<section id="overview" data-reveal class="relative overflow-hidden px-6 py-24 lg:px-8 lg:py-32">
				<div class="pointer-events-none absolute inset-0 -z-10">
					<div class="absolute left-1/2 top-0 h-[28rem] w-[54rem] -translate-x-1/2 rounded-full bg-cyan-500/10 blur-[120px]" />
				</div>
				<div class="mx-auto max-w-4xl text-center">
					<p class="mb-4 font-mono text-[11px] uppercase tracking-[0.2em] text-cyan-300/90">Step 1/5 - Overview</p>
					<div class="mb-8 inline-flex items-center gap-2 rounded-full border border-cyan-500/20 bg-cyan-500/5 px-4 py-1.5 font-mono text-xs uppercase tracking-widest text-cyan-300">
						<span class="h-1.5 w-1.5 animate-pulse rounded-full bg-cyan-400"></span>
						Runtime observability for C++ and embedded
					</div>
					<h1 class="bg-gradient-to-b from-white to-slate-500 bg-clip-text text-4xl font-semibold tracking-tight text-transparent sm:text-6xl lg:text-7xl">
						Understand, replay, and validate your system while it runs.
					</h1>
					<p class="mx-auto mt-8 max-w-2xl text-lg leading-relaxed text-slate-400 sm:text-xl">
						VarMonitor is a runtime observability and replay platform for C++ systems. It helps teams monitor internal variables live,
						reproduce issues deterministically, analyze anomalies offline, and test behavior by injecting values in real time through a remote web interface.
					</p>
				</div>
			</section>

			<section data-reveal class="border-t border-white/5 bg-slate-950 px-6 py-14 lg:px-8 lg:py-16">
				<div class="mx-auto max-w-6xl">
					<div class="mx-auto max-w-5xl overflow-hidden rounded-2xl border border-white/10 bg-slate-900/45 p-2 shadow-2xl shadow-black/40 backdrop-blur-sm md:p-3">
						<video
							class="h-auto w-full rounded-xl border border-cyan-500/20 bg-slate-950/80"
							src={architectureVideoSrc}
							autoplay
							loop
							muted
							playsinline
							preload="metadata"
						>
							Your browser does not support embedded videos.
						</video>
						<p class="px-3 pb-2 pt-3 text-center text-xs text-slate-400 md:px-4">
							What you are seeing is a real capture of VarMonitor tracking a large set of internal variables and plotting them live in the runtime dashboard.
						</p>
					</div>
				</div>
			</section>

			<section id="problem" data-reveal class="border-t border-white/5 bg-slate-900 px-6 py-20 lg:px-8 lg:py-24">
				<div class="mx-auto max-w-6xl">
					<div class="mx-auto max-w-2xl text-center">
						<p class="mb-3 font-mono text-[11px] uppercase tracking-[0.2em] text-cyan-300/90">Step 2/5 - Problem + Solution</p>
						<h2 class="font-mono text-sm uppercase tracking-widest text-cyan-400/80">Core Engineering Workflows</h2>
						<p class="mt-4 text-3xl font-semibold tracking-tight text-white md:text-4xl">Capabilities that map to real C++ engineering work.</p>
						<p class="mx-auto mt-3 max-w-2xl text-sm leading-relaxed text-slate-400">
							All workflows run through a modern, easy-to-use interface that also works for non-technical roles, while remaining fully customizable for advanced engineering teams. VarMonitor provides a full web interface for remote access to all capabilities, improving operational flexibility across development and runtime teams.
						</p>
					</div>
					<div class="mt-10 grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-4">
						<article class="rounded-2xl border border-slate-800/50 bg-slate-900/60 p-6 backdrop-blur-md">
							<h3 class="font-mono text-xs uppercase tracking-widest text-cyan-300/90">Live Observability</h3>
							<p class="mt-3 text-sm leading-relaxed text-slate-400">
								Monitor internal variables and event context in real time to understand runtime behavior as it happens, without breaking execution flow.
							</p>
						</article>
						<article id="solution" class="rounded-2xl border border-cyan-400/35 bg-slate-900/60 p-6 shadow-[0_0_24px_rgba(34,211,238,0.12)] backdrop-blur-md">
							<h3 class="font-mono text-xs uppercase tracking-widest text-cyan-300/90">Deterministic Replay</h3>
							<p class="mt-3 text-sm leading-relaxed text-slate-300">
								Record executions and replay the same scenario with stable timing context, making intermittent issues reproducible and fixes verifiable.
							</p>
						</article>
						<article class="rounded-2xl border border-slate-800/50 bg-slate-900/60 p-6 backdrop-blur-md">
							<h3 class="font-mono text-xs uppercase tracking-widest text-cyan-300/90">Runtime Validation</h3>
							<p class="mt-3 text-sm leading-relaxed text-slate-400">
								Inject variable values and run offline analysis/reporting workflows to validate system responses under controlled engineering scenarios.
							</p>
						</article>
						<article class="rounded-2xl border border-slate-800/50 bg-slate-900/60 p-6 backdrop-blur-md">
							<h3 class="font-mono text-xs uppercase tracking-widest text-cyan-300/90">Remote Access</h3>
							<p class="mt-3 text-sm leading-relaxed text-slate-400">
								Access VarMonitor through its remote web interface with a low-friction workflow designed for fast, easy entry from distributed engineering environments.
							</p>
						</article>
					</div>
				</div>
			</section>

			<section id="architecture" data-reveal class="border-t border-white/5 bg-slate-950 px-6 py-24 lg:px-8 lg:py-32">
				<div class="mx-auto max-w-6xl">
					<p class="mb-3 text-center font-mono text-[11px] uppercase tracking-[0.2em] text-cyan-300/90">Step 3/5 - Architecture</p>
					<h2 class="text-center font-mono text-sm uppercase tracking-widest text-cyan-400/80">Architecture (low overhead)</h2>
					<p class="mx-auto mt-4 max-w-3xl text-center text-3xl font-semibold tracking-tight text-white md:text-4xl">
						Low-intrusion runtime insight powered by SHM, ring buffers, and efficient IPC.
					</p>

					<div class="relative mx-auto mt-14 max-w-5xl overflow-hidden rounded-2xl border border-white/10 bg-slate-900/45 p-6 shadow-2xl shadow-black/40 backdrop-blur-sm md:p-8">
						<div class="absolute right-4 top-4 flex flex-wrap justify-end gap-2">
							<span class="rounded-full border border-cyan-500/35 bg-cyan-500/10 px-2.5 py-1 font-mono text-[10px] uppercase tracking-wider text-cyan-300">
								&lt; <span data-counter data-counter-target="1">0</span>ms latency
							</span>
							<span class="rounded-full border border-cyan-500/35 bg-cyan-500/10 px-2.5 py-1 font-mono text-[10px] uppercase tracking-wider text-cyan-300">
								C++<span data-counter data-counter-target="20">0</span> native
							</span>
							<span class="rounded-full border border-cyan-500/35 bg-cyan-500/10 px-2.5 py-1 font-mono text-[10px] uppercase tracking-wider text-cyan-300">SHM zero-copy</span>
						</div>
						<p class="mt-8 text-center font-mono text-xs uppercase tracking-wider text-cyan-200/70 md:mt-10">
							Deterministic performance for flight-critical control loops.
						</p>

						<div class="flex flex-col items-center gap-4 pt-10 md:hidden">
							<button
								type="button"
								data-pipeline-open="cpp"
								class="pipeline-node pipeline-node--cpp w-full max-w-xs rounded-lg border border-cyan-500/30 bg-cyan-500/10 px-4 py-4 text-center transition-all duration-200 hover:border-cyan-400/80 hover:bg-cyan-500/20 hover:shadow-[0_0_28px_rgba(34,211,238,0.35)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan-500/50"
							>
								<p class="font-mono text-xs uppercase tracking-widest text-cyan-300">C++ Core</p>
								<p class="mt-1 font-mono text-[10px] text-cyan-200/60">Details</p>
							</button>
							<div class="flow-vline">
								<span class="flow-vpulse"></span>
							</div>
							<button
								type="button"
								data-pipeline-open="shm"
								class="pipeline-node pipeline-node--shm w-full max-w-xs rounded-xl border-2 border-dashed border-cyan-400/40 bg-gradient-to-br from-cyan-500/10 to-slate-900 px-4 py-6 text-center transition-all duration-200 hover:border-cyan-300/70 hover:bg-cyan-500/15 hover:shadow-[0_0_32px_rgba(34,211,238,0.3)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan-500/50"
							>
								<p class="font-mono text-xs font-semibold uppercase tracking-widest text-cyan-300">SHM</p>
								<p class="mt-1 font-mono text-[10px] text-cyan-200/60">Details</p>
							</button>
							<div class="flow-vline flow-vline--delay">
								<span class="flow-vpulse"></span>
							</div>
							<button
								type="button"
								data-pipeline-open="consumer"
								class="pipeline-node pipeline-node--consumer w-full max-w-xs rounded-lg border border-violet-500/30 bg-violet-500/10 px-4 py-4 text-center transition-all duration-200 hover:border-violet-400/70 hover:bg-violet-500/20 hover:shadow-[0_0_28px_rgba(167,139,250,0.35)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-violet-400/50"
							>
								<p class="font-mono text-xs uppercase tracking-widest text-violet-300">Python Consumer</p>
								<p class="mt-1 font-mono text-[10px] text-violet-200/60">Details</p>
							</button>
						</div>

						<div class="hidden items-center justify-between gap-3 pt-8 md:flex">
							<button
								type="button"
								data-pipeline-open="cpp"
								class="pipeline-node pipeline-node--cpp w-[30%] rounded-lg border border-cyan-500/30 bg-cyan-500/10 px-4 py-8 text-center transition-all duration-200 hover:border-cyan-400/80 hover:bg-cyan-500/20 hover:shadow-[0_0_28px_rgba(34,211,238,0.35)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan-500/50"
							>
								<p class="font-mono text-xs uppercase tracking-widest text-cyan-300">C++ Core</p>
								<p class="mt-2 font-mono text-[10px] text-cyan-200/60">Click for details</p>
							</button>
							<div class="flow-hline">
								<span class="flow-hpulse"></span>
							</div>
							<button
								type="button"
								data-pipeline-open="shm"
								class="pipeline-node pipeline-node--shm w-[30%] rounded-xl border-2 border-dashed border-cyan-400/40 bg-gradient-to-br from-cyan-500/10 to-slate-900 px-4 py-8 text-center transition-all duration-200 hover:border-cyan-300/70 hover:bg-cyan-500/15 hover:shadow-[0_0_32px_rgba(34,211,238,0.3)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan-500/50"
							>
								<p class="font-mono text-xs uppercase tracking-widest text-cyan-300">SHM</p>
								<p class="mt-2 font-mono text-[10px] text-cyan-200/60">Click for details</p>
							</button>
							<div class="flow-hline flow-hline--delay">
								<span class="flow-hpulse"></span>
							</div>
							<button
								type="button"
								data-pipeline-open="consumer"
								class="pipeline-node pipeline-node--consumer w-[30%] rounded-lg border border-violet-500/30 bg-violet-500/10 px-4 py-8 text-center transition-all duration-200 hover:border-violet-400/70 hover:bg-violet-500/20 hover:shadow-[0_0_28px_rgba(167,139,250,0.35)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-violet-400/50"
							>
								<p class="font-mono text-xs uppercase tracking-widest text-violet-300">Python Consumer</p>
								<p class="mt-2 font-mono text-[10px] text-violet-200/60">Click for details</p>
							</button>
						</div>
					</div>
				</div>
			</section>

			<section id="capabilities" data-reveal class="border-t border-white/5 bg-slate-900 px-6 py-24 lg:px-8 lg:py-32">
				<div class="mx-auto max-w-6xl">
					<div class="mx-auto max-w-2xl text-center">
						<p class="mb-3 font-mono text-[11px] uppercase tracking-[0.2em] text-cyan-300/90">Step 4/5 - Capabilities</p>
						<h2 class="font-mono text-sm uppercase tracking-widest text-cyan-400/80">Key Capabilities</h2>
						<p class="mt-4 text-3xl font-semibold tracking-tight text-white md:text-4xl">One core platform, extended by workflow-aligned plugins.</p>
						<p class="mt-3 font-mono text-xs uppercase tracking-wider text-cyan-200/70">
							Plugins adapt to your project and engineering workflow - your workflow does not adapt to the tool.
						</p>
					</div>

					<div class="mt-14 grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3">
						{
							extensibilityCards.map((item) => (
								<article
									data-reveal
									data-plugin-open={item.videoModalSrc || ""}
									data-plugin-title={item.title}
									role={item.videoModalSrc ? "button" : undefined}
									tabindex={item.videoModalSrc ? "0" : undefined}
									class={`group relative isolate overflow-hidden rounded-2xl border bg-slate-900/60 p-5 backdrop-blur-md transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_16px_42px_rgba(0,0,0,0.45)] ${
										item.featured
											? "border-cyan-400/55 shadow-[0_12px_34px_rgba(34,211,238,0.2)] before:opacity-80"
											: 'border-slate-800/50'
									}`}
								>
									<div class="absolute inset-0 rounded-2xl border border-transparent transition-colors duration-300 group-hover:border-cyan-500/50"></div>
									<div class="pointer-events-none before:absolute before:-inset-px before:rounded-xl before:bg-gradient-to-r before:from-cyan-500/20 before:to-cyan-400/10 before:opacity-0 before:blur-xl before:transition-opacity before:duration-300 before:content-[''] group-hover:before:opacity-100"></div>
									<div class="relative z-10">
										<div class="flex items-start gap-3">
											<div class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-cyan-500/10 text-cyan-400">
												<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
													<path stroke-linecap="round" stroke-linejoin="round" d={item.svgPath}></path>
												</svg>
											</div>
											<h3 class="text-base font-semibold text-cyan-300">{item.title}</h3>
										</div>
										<p class="mt-3 text-sm leading-relaxed text-slate-400">{item.body}</p>
										{
											item.videoThumbSrc && (
												<video
													class="mt-4 h-auto w-full rounded-lg border border-cyan-500/20 bg-slate-950/80"
													src={item.videoThumbSrc}
													autoplay
													loop
													muted
													playsinline
													preload="metadata"
												>
													Your browser does not support embedded videos.
												</video>
											)
										}
									</div>
								</article>
							))
						}
					</div>
				</div>
			</section>

			<section id="start" data-reveal class="border-t border-white/5 bg-slate-950 px-6 py-24 lg:px-8 lg:py-28">
				<div class="mx-auto max-w-4xl text-center">
					<p class="mb-3 font-mono text-[11px] uppercase tracking-[0.2em] text-cyan-300/90">Step 5/5 - Start</p>
					<h2 class="text-3xl font-semibold tracking-tight text-white md:text-4xl">Easy to integrate, engineered for ultra-light runtime impact.</h2>
					<p class="mx-auto mt-4 max-w-2xl text-slate-400">
