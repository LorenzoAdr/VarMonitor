		<script is:inline>
			(() => {
				const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
				const revealNodes = document.querySelectorAll('[data-reveal]');
				const observer = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							if (entry.isIntersecting) {
								entry.target.classList.add('is-visible');
								observer.unobserve(entry.target);
							}
						});
					},
					{ threshold: 0.14, rootMargin: '0px 0px -10% 0px' },
				);
				revealNodes.forEach((node) => observer.observe(node));

				const pipelineSection = document.getElementById('native-pipeline');
				const counters = Array.from(document.querySelectorAll('[data-counter]'));
				const animateCounter = (el) => {
					const target = Number(el.getAttribute('data-counter-target') || '0');
					const duration = 1200;
					const startTime = performance.now();
					const step = (now) => {
						const progress = Math.min((now - startTime) / duration, 1);
						const eased = 1 - Math.pow(1 - progress, 3);
						el.textContent = String(Math.round(target * eased));
						if (progress < 1) requestAnimationFrame(step);
					};
					requestAnimationFrame(step);
				};
				if (prefersReducedMotion) {
					counters.forEach((el) => {
						el.textContent = String(el.getAttribute('data-counter-target') || '0');
					});
				} else if (pipelineSection && counters.length) {
					const metricsObserver = new IntersectionObserver(
						(entries) => {
							entries.forEach((entry) => {
								if (!entry.isIntersecting) return;
								counters.forEach((counter) => animateCounter(counter));
								metricsObserver.disconnect();
							});
						},
						{ threshold: 0.35 },
					);
					metricsObserver.observe(pipelineSection);
				}

				const drawerRoot = document.getElementById('pipeline-drawer-root');
				const drawerAside = document.getElementById('pipeline-drawer-panel');
				const drawerTitleEl = document.getElementById('pipeline-drawer-title');
				const panelEls = document.querySelectorAll('[data-pipeline-panel]');
				const drawerTitles = { cpp: 'C++ Core', shm: 'Shared memory', consumer: 'Python consumer' };

				let drawerCloseTimer = 0;
				const closeDrawer = () => {
					if (!drawerRoot) return;
					drawerRoot.classList.remove('pipeline-drawer--open');
					drawerRoot.setAttribute('aria-hidden', 'true');
					document.body.style.overflow = '';
					window.clearTimeout(drawerCloseTimer);
					drawerCloseTimer = window.setTimeout(() => {
						drawerRoot.classList.add('hidden');
					}, 320);
				};

				const openDrawer = (id) => {
					if (!drawerRoot || !drawerAside) return;
					panelEls.forEach((panel) => {
						panel.classList.toggle('hidden', panel.getAttribute('data-pipeline-panel') !== id);
					});
					if (drawerTitleEl && drawerTitles[id]) drawerTitleEl.textContent = drawerTitles[id];
					drawerRoot.classList.remove('hidden');
					drawerRoot.setAttribute('aria-hidden', 'false');
					document.body.style.overflow = 'hidden';
					requestAnimationFrame(() => {
						drawerRoot.classList.add('pipeline-drawer--open');
					});
					const closeBtn = drawerAside.querySelector('[data-pipeline-drawer-close]');
					if (closeBtn instanceof HTMLElement) closeBtn.focus();
				};

				document.querySelectorAll('[data-pipeline-open]').forEach((btn) => {
					btn.addEventListener('click', () => {
						const id = btn.getAttribute('data-pipeline-open');
						if (id) openDrawer(id);
					});
				});
				document.querySelectorAll('[data-pipeline-drawer-close]').forEach((el) => {
					el.addEventListener('click', closeDrawer);
				});
				document.addEventListener('keydown', (e) => {
					if (e.key === 'Escape' && drawerRoot?.classList.contains('pipeline-drawer--open')) closeDrawer();
				});

				const pluginModalRoot = document.getElementById('plugin-video-modal-root');
				const pluginVideoEl = document.getElementById('plugin-video-player');
				const pluginVideoTitle = document.getElementById('plugin-video-title');
				const openPluginVideo = (src, title) => {
					if (!pluginModalRoot || !(pluginVideoEl instanceof HTMLVideoElement)) return;
					if (!src) return;
					if (pluginVideoTitle) pluginVideoTitle.textContent = title || 'Plugin video';
					pluginVideoEl.src = src;
					pluginModalRoot.classList.remove('hidden');
					pluginModalRoot.setAttribute('aria-hidden', 'false');
					document.body.style.overflow = 'hidden';
					requestAnimationFrame(() => {
						pluginModalRoot.classList.add('plugin-video-modal--open');
					});
					void pluginVideoEl.play().catch(() => {});
				};
				const closePluginVideo = () => {
					if (!pluginModalRoot || !(pluginVideoEl instanceof HTMLVideoElement)) return;
					pluginModalRoot.classList.remove('plugin-video-modal--open');
					pluginModalRoot.setAttribute('aria-hidden', 'true');
					document.body.style.overflow = '';
					setTimeout(() => {
						pluginVideoEl.pause();
						pluginVideoEl.removeAttribute('src');
						pluginVideoEl.load();
						pluginModalRoot.classList.add('hidden');
					}, 280);
				};
				document.querySelectorAll('[data-plugin-open]').forEach((el) => {
					const src = el.getAttribute('data-plugin-open');
					const title = el.getAttribute('data-plugin-title') || '';
					if (!src) return;
					el.addEventListener('click', () => openPluginVideo(src, title));
					el.addEventListener('keydown', (e) => {
						if (e.key === 'Enter' || e.key === ' ') {
							e.preventDefault();
							openPluginVideo(src, title);
						}
					});
				});
				document.querySelectorAll('[data-plugin-video-close]').forEach((el) => {
					el.addEventListener('click', closePluginVideo);
				});
				document.addEventListener('keydown', (e) => {
					if (e.key === 'Escape' && pluginModalRoot?.classList.contains('plugin-video-modal--open')) closePluginVideo();
				});

				const stepOrder = ['overview', 'problem', 'architecture', 'capabilities', 'start'];
				const stepLabels = {
					overview: 'Overview',
					problem: 'Problem+Solution',
					architecture: 'Architecture',
					capabilities: 'Capabilities',
					start: 'Start',
				};
				const stepLabel = document.getElementById('vm-stepper-current');
				let activeStepIdx = 0;

				const applyStepperState = (idx) => {
					activeStepIdx = idx;
					const key = stepOrder[idx];
					const name = stepLabels[key] || key;
					if (stepLabel) stepLabel.textContent = `${idx + 1}/${stepOrder.length} ${name}`;
				};

				const stepSections = stepOrder
					.map((id) => ({ id, el: document.getElementById(id) }))
					.filter((entry) => entry.el);

				if (stepSections.length) {
					const stepObserver = new IntersectionObserver(
						(entries) => {
							entries.forEach((entry) => {
								if (!entry.isIntersecting) return;
								const idx = stepOrder.indexOf(entry.target.id);
								if (idx >= 0) applyStepperState(idx);
							});
						},
						{ threshold: 0.35, rootMargin: '-15% 0px -55% 0px' },
					);
					stepSections.forEach((entry) => stepObserver.observe(entry.el));
					applyStepperState(0);
				}
			})();
		</script>
	</body>
